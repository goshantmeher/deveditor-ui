{
  "name": "@deveditor/ui",
  "version": "0.0.2",
  "description": "A meticulously crafted, headless-first UI component library for React",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.16.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "jsdom": "^25.0.0"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "design-system",
    "tailwindcss",
    "radix-ui",
    "accessible",
    "headless"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/goshantmeher/deveditor-ui",
    "directory": "packages/ui"
  },
  "homepage": "https://deveditor.io",
  "bugs": {
    "url": "https://github.com/goshantmeher/deveditor-ui/issues"
  },
  "author": "Goshant Meher",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
